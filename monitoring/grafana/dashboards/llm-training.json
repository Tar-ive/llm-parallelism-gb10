{
  "uid": "llm-training",
  "title": "LLM Training (per-step)",
  "tags": ["training"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tag", "label": "Run tag", "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(llm_train_step_ms, tag)",
        "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" }, "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Throughput (tokens/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_tokens_per_s{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Achieved TFLOPS  (the real utilization meter)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_tflops{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 3, "type": "timeseries", "title": "MFU % of assumed peak",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_mfu_pct{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Step time (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0, "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_step_ms{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Loss",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_loss{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "torch.cuda.max_memory_allocated (GiB)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "decgbytes", "min": 0, "custom": { "fillOpacity": 12 } }, "overrides": [] },
      "targets": [
        { "expr": "llm_train_mem_gib{tag=~\"$tag\"}", "legendFormat": "{{tag}}", "refId": "A" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Training vs GPU: TFLOPS overlaid on power (W)",
      "description": "The core lesson from the parallelism experiments: power tracks useful work far better than GPU%.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "fillOpacity": 8 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "power W" }, "properties": [ { "id": "unit", "value": "watt" }, { "id": "custom.axisPlacement", "value": "right" } ] },
        { "matcher": { "id": "byName", "options": "GPU util %" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" } ] }
      ] },
      "targets": [
        { "expr": "llm_train_tflops{tag=~\"$tag\"}", "legendFormat": "TFLOPS {{tag}}", "refId": "A" },
        { "expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "power W", "refId": "B" },
        { "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "GPU util %", "refId": "C" }
      ]
    }
  ]
}
